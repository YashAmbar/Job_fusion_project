# Supabase Configuration
# 1. Create a project at https://supabase.com
# 2. Get these from Project Settings -> API
# 3. Rename this file to .env and fill in the values

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here # Use service_role key, NOT anon key

# JWT Secret for auth tokens
JWT_SECRET=your-random-secret-key-here

# Email Notifications (Gmail App Password)
# 1. Enable 2FA on your Gmail: https://myaccount.google.com/security
# 2. Create App Password: https://myaccount.google.com/apppasswords
# 3. Use the 16-char app password below
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password

# SMS Notifications (Twilio - Optional)
# Sign up at https://www.twilio.com for free trial
TWILIO_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890
